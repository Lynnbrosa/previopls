# =========================================================================
# PrevioPLS Security API — variáveis de ambiente
# =========================================================================
# Em produção: gerencie via secret manager (AWS SSM, Vault, GCP Secret Mgr).
# NUNCA commitar valores reais. Este arquivo é só template.
# =========================================================================

APP_ENV=development
APP_NAME=previo-pls-security
APP_VERSION=1.0.0

# ---- Database ----
DATABASE_URL=postgresql+psycopg://previopls:previopls@db:5432/previopls

# ---- JWT (RS256 — assinatura assimétrica) ----
# Gere com: ./scripts/gen_rsa_keys.sh
JWT_PRIVATE_KEY_PATH=./keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt_public.pem
JWT_ISSUER=previo-pls
JWT_AUDIENCE=previo-pls-clients
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

# ---- Fernet — criptografia de CPF at-rest ----
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 32 bytes URL-safe base64.
FERNET_KEY=Z0FBQUFBQm5BQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUFBQUE=

# Chave separada para HMAC determinístico do CPF (busca por igualdade).
# Hash NÃO retorna o plaintext — só serve pra lookup.
CPF_HASH_PEPPER=troque-em-producao-para-um-valor-aleatorio-de-32-bytes-no-minimo

# Chave compartilhada para HMAC em payloads críticos (POST /v1/clientes).
HMAC_PAYLOAD_SECRET=troque-em-producao-compartilhada-com-clientes-confiaveis

# ---- CORS — whitelist explícita (separar por vírgula) ----
CORS_ORIGINS=https://app.previopls.local,https://admin.previopls.local

# ---- Rate limit (por IP) ----
RATE_LIMIT_GLOBAL=100/minute
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_LLM=10/minute

# ---- Lockout anti brute-force ----
LOCKOUT_MAX_FAILURES=5
LOCKOUT_WINDOW_SECONDS=60
LOCKOUT_DURATION_SECONDS=900

# ---- LGPD retention ----
RETENTION_YEARS=5

# ---- Webhook para alertas de segurança (opcional) ----
SECURITY_ALERT_WEBHOOK_URL=
