{
  "expo": {
    "name": "PrevioPLS",
    "slug": "previo-pls",
    "version": "1.0.0",
    "scheme": "previopls",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.previopls.mobile"
    },
    "android": {
      "package": "com.previopls.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#003478"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Use Face ID para acessar credenciais do consultor."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#003478"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
