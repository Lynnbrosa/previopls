# URL pública do backend. Em dev local com docker-compose unificado, aponta
# para o nginx que termina TLS em https://localhost (aceita self-signed).
NEXT_PUBLIC_API_URL=https://localhost

# URL interna do backend, usada pelos server components / API routes do Next.js
# que rodam dentro da rede compose. No demo unificado aponta ao Core direto
# (que traz seed de usuários e leads). Em produção, com gateway/edge proxy
# wired, mudaria para http://gateway:8000.
INTERNAL_GATEWAY_URL=http://core:5000
