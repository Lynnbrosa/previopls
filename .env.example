DATABASE_URL=jdbc:postgresql://localhost:5432/previopls
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Auth
JWT_SECRET=trocar-em-producao-usar-chave-com-pelo-menos-32-bytes-aleatoria
JWT_EXPIRATION_HOURS=8

# CORS — lista separada por vírgula
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# Criptografia em repouso (AES-256 — 32 bytes em Base64)
# Gere uma chave real em prod com: openssl rand -base64 32
APP_CRYPTO_KEY=cHJldmlvcGxzLWRldi1rZXktMzItYnl0ZXMtWFhYWFg=

# Anti-brute-force no login
LOCKOUT_MAX_ATTEMPTS=5
LOCKOUT_WINDOW_MINUTES=15

# Rate limiting (por IP)
RATE_LIMIT_LOGIN=5
RATE_LIMIT_DEFAULT=200
